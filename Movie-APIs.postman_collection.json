{
  "info": {
    "name": "Movie Reservation System APIs",
    "description": "Complete Postman collection for all microservices APIs in the Movie Reservation System. Includes authentication, CRUD operations for users, movies, cinemas, seats, schedules, and tickets.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{user_url}}/api/v1/auth/login",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login to get JWT token. Update email/password as needed."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('jwt_token', pm.response.headers.get('Authorization'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{user_url}}/api/v1/auth/validate",
              "host": ["{{user_url}}"],
              "path": ["api", "v1", "auth", "validate"]
            },
            "description": "Validate JWT token."
          }
        }
      ]
    },
